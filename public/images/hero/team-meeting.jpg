<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
<defs>
  <linearGradient id="heroGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
    <stop offset="0%" style="stop-color:#1e1b4b;stop-opacity:1" />
    <stop offset="30%" style="stop-color:#312e81;stop-opacity:1" />
    <stop offset="70%" style="stop-color:#1e40af;stop-opacity:1" />
    <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
  </linearGradient>
  <linearGradient id="accent3" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0.8" />
    <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:0.8" />
  </linearGradient>
</defs>

<!-- Background -->
<rect width="1920" height="1080" fill="url(#heroGrad3)"/>

<!-- Conference table representation -->
<ellipse cx="960" cy="540" rx="400" ry="200" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 255, 255, 0.15)" stroke-width="3"/>

<!-- Meeting participants (abstract) -->
<circle cx="600" cy="400" r="40" fill="rgba(255, 255, 255, 0.7)"/>
<circle cx="800" cy="350" r="40" fill="rgba(255, 255, 255, 0.6)"/>
<circle cx="1120" cy="350" r="40" fill="rgba(255, 255, 255, 0.65)"/>
<circle cx="1320" cy="400" r="40" fill="rgba(255, 255, 255, 0.7)"/>
<circle cx="700" cy="700" r="40" fill="rgba(255, 255, 255, 0.6)"/>
<circle cx="1220" cy="700" r="40" fill="rgba(255, 255, 255, 0.65)"/>

<!-- Presentation screen -->
<rect x="760" y="150" width="400" height="250" rx="15" fill="rgba(15, 23, 42, 0.9)" stroke="rgba(6, 182, 212, 0.4)" stroke-width="3"/>

<!-- Presentation content -->
<rect x="780" y="170" width="360" height="40" rx="5" fill="url(#accent3)"/>
<rect x="780" y="230" width="280" height="20" rx="3" fill="rgba(255, 255, 255, 0.5)"/>
<rect x="780" y="260" width="320" height="20" rx="3" fill="rgba(255, 255, 255, 0.4)"/>
<rect x="780" y="290" width="240" height="20" rx="3" fill="rgba(255, 255, 255, 0.45)"/>

<!-- Charts/graphs on screen -->
<rect x="780" y="330" width="100" height="50" rx="5" fill="rgba(6, 182, 212, 0.3)"/>
<rect x="900" y="320" width="100" height="60" rx="5" fill="rgba(59, 130, 246, 0.3)"/>
<rect x="1020" y="340" width="100" height="40" rx="5" fill="rgba(139, 92, 246, 0.3)"/>

<!-- Connection lines showing collaboration -->
<path d="M640 440 Q800 480 960 440" stroke="rgba(6, 182, 212, 0.4)" stroke-width="2" fill="none"/>
<path d="M1080 390 Q1200 430 1280 440" stroke="rgba(59, 130, 246, 0.4)" stroke-width="2" fill="none"/>
<path d="M740 660 Q960 600 1180 660" stroke="rgba(139, 92, 246, 0.4)" stroke-width="2" fill="none"/>

<!-- Laptops/devices on table -->
<rect x="550" y="480" width="100" height="60" rx="8" fill="rgba(255, 255, 255, 0.1)" stroke="rgba(255, 255, 255, 0.2)" stroke-width="1"/>
<rect x="1270" y="480" width="100" height="60" rx="8" fill="rgba(255, 255, 255, 0.1)" stroke="rgba(255, 255, 255, 0.2)" stroke-width="1"/>

<!-- Device screens -->
<rect x="560" y="490" width="80" height="40" rx="3" fill="rgba(15, 23, 42, 0.8)"/>
<rect x="1280" y="490" width="80" height="40" rx="3" fill="rgba(15, 23, 42, 0.8)"/>

<!-- Ambient elements -->
<circle cx="200" cy="200" r="100" fill="rgba(6, 182, 212, 0.1)" opacity="0.6"/>
<circle cx="1700" cy="850" r="120" fill="rgba(139, 92, 246, 0.1)" opacity="0.5"/>
<circle cx="100" cy="900" r="80" fill="rgba(59, 130, 246, 0.1)" opacity="0.7"/>

<!-- Innovation symbols -->
<rect x="1750" y="100" width="80" height="80" rx="10" fill="rgba(6, 182, 212, 0.2)" stroke="rgba(6, 182, 212, 0.4)" stroke-width="2"/>
<rect x="90" y="50" width="80" height="80" rx="10" fill="rgba(139, 92, 246, 0.2)" stroke="rgba(139, 92, 246, 0.4)" stroke-width="2"/>

<!-- Light rays from presentation -->
<path d="M960 150 L960 50" stroke="rgba(6, 182, 212, 0.2)" stroke-width="4" opacity="0.6"/>
<path d="M960 150 L1100 80" stroke="rgba(6, 182, 212, 0.15)" stroke-width="3" opacity="0.5"/>
<path d="M960 150 L820 80" stroke="rgba(6, 182, 212, 0.15)" stroke-width="3" opacity="0.5"/>

</svg>