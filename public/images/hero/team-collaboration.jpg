<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
<defs>
  <linearGradient id="heroGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
    <stop offset="0%" style="stop-color:#0f172a;stop-opacity:1" />
    <stop offset="30%" style="stop-color:#1e293b;stop-opacity:1" />
    <stop offset="70%" style="stop-color:#334155;stop-opacity:1" />
    <stop offset="100%" style="stop-color:#1e40af;stop-opacity:1" />
  </linearGradient>
  <linearGradient id="accent1" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.8" />
    <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.8" />
  </linearGradient>
</defs>

<!-- Background -->
<rect width="1920" height="1080" fill="url(#heroGrad1)"/>

<!-- Abstract shapes representing collaboration -->
<circle cx="400" cy="300" r="120" fill="rgba(59, 130, 246, 0.1)" opacity="0.6"/>
<circle cx="1500" cy="700" r="180" fill="rgba(6, 182, 212, 0.1)" opacity="0.4"/>
<circle cx="800" cy="800" r="100" fill="rgba(139, 92, 246, 0.1)" opacity="0.5"/>

<!-- Team collaboration elements -->
<rect x="300" y="400" width="400" height="250" rx="20" fill="rgba(255, 255, 255, 0.1)" stroke="rgba(255, 255, 255, 0.2)" stroke-width="2"/>
<rect x="1200" y="300" width="400" height="250" rx="20" fill="rgba(255, 255, 255, 0.1)" stroke="rgba(255, 255, 255, 0.2)" stroke-width="2"/>

<!-- Code/screen representations -->
<rect x="320" y="420" width="360" height="20" rx="10" fill="url(#accent1)"/>
<rect x="320" y="460" width="280" height="15" rx="7" fill="rgba(255, 255, 255, 0.3)"/>
<rect x="320" y="490" width="320" height="15" rx="7" fill="rgba(255, 255, 255, 0.2)"/>
<rect x="320" y="520" width="200" height="15" rx="7" fill="rgba(255, 255, 255, 0.25)"/>

<rect x="1220" y="320" width="360" height="20" rx="10" fill="url(#accent1)"/>
<rect x="1220" y="360" width="280" height="15" rx="7" fill="rgba(255, 255, 255, 0.3)"/>
<rect x="1220" y="390" width="320" height="15" rx="7" fill="rgba(255, 255, 255, 0.2)"/>
<rect x="1220" y="420" width="200" height="15" rx="7" fill="rgba(255, 255, 255, 0.25)"/>

<!-- Connection lines representing collaboration -->
<path d="M700 525 Q960 400 1200 425" stroke="rgba(59, 130, 246, 0.4)" stroke-width="3" fill="none" stroke-dasharray="10,5"/>
<path d="M500 400 Q750 250 1300 300" stroke="rgba(6, 182, 212, 0.3)" stroke-width="2" fill="none" stroke-dasharray="8,4"/>

<!-- Abstract people/team icons -->
<circle cx="450" cy="350" r="25" fill="rgba(255, 255, 255, 0.8)"/>
<circle cx="550" cy="350" r="25" fill="rgba(255, 255, 255, 0.7)"/>
<circle cx="650" cy="350" r="25" fill="rgba(255, 255, 255, 0.6)"/>

<circle cx="1350" cy="250" r="25" fill="rgba(255, 255, 255, 0.8)"/>
<circle cx="1450" cy="250" r="25" fill="rgba(255, 255, 255, 0.7)"/>

<!-- Tech elements -->
<rect x="100" y="200" width="80" height="80" rx="10" fill="rgba(59, 130, 246, 0.2)" stroke="rgba(59, 130, 246, 0.4)" stroke-width="2"/>
<rect x="1700" y="850" width="80" height="80" rx="10" fill="rgba(6, 182, 212, 0.2)" stroke="rgba(6, 182, 212, 0.4)" stroke-width="2"/>

<!-- Subtle grid pattern -->
<defs>
  <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
    <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
  </pattern>
</defs>
<rect width="1920" height="1080" fill="url(#grid)"/>

</svg>