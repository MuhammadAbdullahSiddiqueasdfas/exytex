<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
<defs>
  <linearGradient id="heroGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
    <stop offset="0%" style="stop-color:#0c1426;stop-opacity:1" />
    <stop offset="40%" style="stop-color:#1e3a8f;stop-opacity:1" />
    <stop offset="80%" style="stop-color:#3730a3;stop-opacity:1" />
    <stop offset="100%" style="stop-color:#1f2937;stop-opacity:1" />
  </linearGradient>
  <linearGradient id="accent2" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0.8" />
    <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.8" />
  </linearGradient>
</defs>

<!-- Background -->
<rect width="1920" height="1080" fill="url(#heroGrad2)"/>

<!-- Modern office elements -->
<rect x="200" y="200" width="600" height="400" rx="15" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 255, 255, 0.15)" stroke-width="2"/>
<rect x="1100" y="300" width="600" height="400" rx="15" fill="rgba(255, 255, 255, 0.08)" stroke="rgba(255, 255, 255, 0.15)" stroke-width="2"/>

<!-- Screens/monitors -->
<rect x="250" y="250" width="500" height="300" rx="10" fill="rgba(15, 23, 42, 0.9)" stroke="rgba(139, 92, 246, 0.3)" stroke-width="2"/>
<rect x="1150" y="350" width="500" height="300" rx="10" fill="rgba(15, 23, 42, 0.9)" stroke="rgba(6, 182, 212, 0.3)" stroke-width="2"/>

<!-- Screen content -->
<rect x="270" y="270" width="460" height="30" rx="5" fill="url(#accent2)"/>
<rect x="270" y="320" width="350" height="15" rx="3" fill="rgba(255, 255, 255, 0.4)"/>
<rect x="270" y="350" width="400" height="15" rx="3" fill="rgba(255, 255, 255, 0.3)"/>
<rect x="270" y="380" width="300" height="15" rx="3" fill="rgba(255, 255, 255, 0.35)"/>
<rect x="270" y="410" width="380" height="15" rx="3" fill="rgba(255, 255, 255, 0.25)"/>

<rect x="1170" y="370" width="460" height="30" rx="5" fill="url(#accent2)"/>
<rect x="1170" y="420" width="350" height="15" rx="3" fill="rgba(255, 255, 255, 0.4)"/>
<rect x="1170" y="450" width="400" height="15" rx="3" fill="rgba(255, 255, 255, 0.3)"/>
<rect x="1170" y="480" width="300" height="15" rx="3" fill="rgba(255, 255, 255, 0.35)"/>

<!-- Floating elements representing productivity -->
<circle cx="900" cy="150" r="60" fill="rgba(139, 92, 246, 0.15)" stroke="rgba(139, 92, 246, 0.3)" stroke-width="2"/>
<circle cx="1000" cy="900" r="80" fill="rgba(6, 182, 212, 0.15)" stroke="rgba(6, 182, 212, 0.3)" stroke-width="2"/>

<!-- Abstract data visualization -->
<rect x="880" y="130" width="40" height="40" rx="5" fill="rgba(255, 255, 255, 0.6)"/>
<rect x="980" y="880" width="40" height="40" rx="5" fill="rgba(255, 255, 255, 0.6)"/>

<!-- Connecting lines -->
<path d="M800 500 Q960 350 1150 500" stroke="rgba(139, 92, 246, 0.4)" stroke-width="3" fill="none" stroke-dasharray="12,6"/>

<!-- Modern furniture/desk elements -->
<rect x="200" y="580" width="600" height="20" rx="10" fill="rgba(255, 255, 255, 0.1)"/>
<rect x="1100" y="680" width="600" height="20" rx="10" fill="rgba(255, 255, 255, 0.1)"/>

<!-- Ambient lighting effects -->
<circle cx="100" cy="100" r="150" fill="rgba(139, 92, 246, 0.05)" opacity="0.8"/>
<circle cx="1800" cy="980" r="200" fill="rgba(6, 182, 212, 0.05)" opacity="0.6"/>

<!-- Tech icons -->
<rect x="50" y="800" width="60" height="60" rx="8" fill="rgba(139, 92, 246, 0.2)" stroke="rgba(139, 92, 246, 0.4)" stroke-width="2"/>
<rect x="1800" y="200" width="60" height="60" rx="8" fill="rgba(6, 182, 212, 0.2)" stroke="rgba(6, 182, 212, 0.4)" stroke-width="2"/>

</svg>